# ENAUNITY Production Environment
# Copy to .env.production and fill in values

# ── Database ──
DATABASE_URL="file:./prod.db"

# ── Auth ──
JWT_SECRET="CHANGE_ME_STRONG_RANDOM_SECRET"
ADMIN_SECRET_PATH="/x-control-eu-7294"
ADMIN_SESSION_TIMEOUT_MINUTES=480

# ── Site URLs ──
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ── Convergence Engines (DO NOT change in production) ──
MARKETPLACE_ENGINE=hub
LEGACY_MARKETPLACE_ENABLED=false
NEXT_PUBLIC_LEGACY_MARKETPLACE_ENABLED=false
MARKETPLACE_ALLOW_MOCK=false

ACCOUNTING_ENGINE=dealer_account
LEGACY_DEALER_BALANCE_ENABLED=false

ORDER_ENGINE=core
LEGACY_DEALER_ORDER_ENABLED=false
DEALER_ORDER_MIRROR_ENABLED=false

WAREHOUSE_ENGINE=core
LEGACY_DEALER_WAREHOUSE_ENABLED=false
DEALER_WAREHOUSE_MIRROR_ENABLED=false

INVOICE_ENGINE=invoice_model
LEGACY_ORDER_PDF_ENABLED=false

# ── Cron ──
CRON_SECRET="CHANGE_ME_CRON_SECRET"

# ── SMTP ──
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"

# ── Payment Provider (default) ──
PAYMENT_PROVIDER=MANUAL

# ── EsnekPOS (hoppa) ──
# MERCHANT_ID = Merchant Public Token (panelden)
# SECRET = Merchant KEY
ESNEKPOS_ENABLED=false
ESNEKPOS_MERCHANT_ID=""
ESNEKPOS_SECRET=""
ESNEKPOS_BACK_URL="https://yourdomain.com/api/payments/callback/esnekpos"
ESNEKPOS_API_URL="https://posservice.esnekpos.com"
ESNEKPOS_SANDBOX=false

# ── İyzico ──
IYZICO_ENABLED=false
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL=""
IYZICO_SANDBOX=false

# ── HIVE ──
HIVE_ENABLED=true
HIVE_SALES_ACTIVE=false
HIVE_BASE_URL="https://hive.thiqos.com"
HIVE_PROXY_MODE=internal
HIVE_TIMEOUT=8000

# ── Shipping ──
BASITKARGO_API_TOKEN=""
KARGONOMI_API_TOKEN=""
KARGONOMI_APP_KEY=""

# ── Stripe (optional, legacy order checkout) ──
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Analytics (optional) ──
NEXT_PUBLIC_GA_ID=""
