  order          DealerOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  coreOrderId    String?
  coreOrder      Order?   @relation("CoreOrderWarehouse", fields: [coreOrderId], references: [id], onDelete: SetNull)
  productId      String?
  catalogItem    ProductCatalogItem? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku            String   @default("")
  location       String   @default("MAIN")
  stock          Int      @default(0)
  reservedStock  Int      @default(0)
  availableStock Int      @default(0)
  movementType   String
  quantity       Int      @default(0)
  notes          String   @default("")
  createdAt      DateTime @default(now())

  @@index([dealerId])
  @@index([orderId])
  @@index([coreOrderId])
  @@index([sku])
  @@index([location])
}

// ── Marketplace Hub ──

model MarketplaceSyncLog {
  id            String   @id @default(cuid())
  connectionId  String
  connection    MarketplaceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  marketplace   String
  status        String   @default("RUNNING")
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  newOrders     Int      @default(0)
  updatedOrders Int      @default(0)
  errorCount    Int      @default(0)
  errorMessage  String   @default("")
  detailsJson   String   @default("{}")
  createdAt     DateTime @default(now())

  @@index([connectionId])
  @@index([createdAt])
}

model MarketplaceWebhookEvent {
  id           String   @id @default(cuid())
  connectionId String?
  connection   MarketplaceConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  marketplace  String
  eventType    String
  payloadJson  String   @default("{}")
  status       String   @default("RECEIVED")
  errorMessage String   @default("")
  createdAt    DateTime @default(now())

  @@index([marketplace])
  @@index([eventType])
  @@index([createdAt])
}

model PaymentMethodPolicy {
  id                  String   @id @default(cuid())
  scope               String   // GLOBAL | GROUP | DEALER
  scopeKey            String   @default("")
  cardEnabled         Boolean?
  bankTransferEnabled Boolean?
  balanceEnabled      Boolean?
  updatedBy           String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([scope, scopeKey])
}

model ThyronixBulkJob {
  id             String   @id @default(cuid())
  tenantDealerId String   @default("")
  userId         String   @default("")
  action         String
  scope          String   // ids | filter | catalog
  filtersJson    String   @default("{}")
  paramsJson     String   @default("{}")
  productIdsJson String   @default("[]")
  status         String   @default("pending")
  totalCount     Int      @default(0)
  processedCount Int      @default(0)
  failedCount    Int      @default(0)
  lastError      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([tenantDealerId])
}

// LinkSlash Chrome Extension capture queue (synced to IndexedDB on app load)
model LinkSlashCapture {
  id          String   @id @default(cuid())
  userId      String
  dealerId    String   @default("")
  url         String
  title       String   @default("")
  description String   @default("")
  image       String   @default("")
  favicon     String   @default("")
  domain      String   @default("")
  sourceType  String   @default("other")
  tagsJson    String   @default("[]")
  aiSummary   String   @default("")
  aiCategory  String   @default("")
  status      String   @default("pending") // pending | synced
  createdAt   DateTime @default(now())
  syncedAt    DateTime?

  @@index([userId, status])
  @@index([dealerId])
  @@index([url])
}

// LinkSlash Cloud Sync — persistent link library per user/tenant
model LinkSlashLink {
  id            String    @id @default(cuid())
  tenantId      String    @default("")
  userId        String
  url           String
  normalizedUrl String
  title         String    @default("")
  description   String    @default("")
  rawText       String    @default("")
  aiSummary       String    @default("")
  aiAnalysisJson  String    @default("{}")
  aiAnalyzedAt    DateTime?
  sourceType      String    @default("other")
  platform      String    @default("website")
  domain        String    @default("")
  imageUrl      String    @default("")
  faviconUrl    String    @default("")
  notes         String    @default("")
  categorySlug  String    @default("")
  status        String    @default("active")
  importance    Int       @default(0)
  language      String    @default("")
  isFavorite    Boolean   @default(false)
  isArchived    Boolean   @default(false)
  deletedAt     DateTime?
  localId       String    @default("")
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  linkTags      LinkSlashLinkTag[]

  @@unique([tenantId, userId, normalizedUrl])
  @@index([tenantId, userId])
  @@index([userId, updatedAt])
  @@index([localId])
}

model LinkSlashCategory {
  id        String   @id @default(cuid())
  tenantId  String   @default("")
  userId    String
  name      String
  slug      String
  emoji     String   @default("")
  color     String   @default("#6366f1")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, slug])
  @@index([tenantId, userId])
}

model LinkSlashTag {
  id        String   @id @default(cuid())
  tenantId  String   @default("")
  userId    String
  name      String
  slug      String
  color     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  linkTags  LinkSlashLinkTag[]

  @@unique([tenantId, userId, slug])
  @@index([tenantId, userId])
}

model LinkSlashLinkTag {
  id        String   @id @default(cuid())
  linkId    String
  tagId     String
  createdAt DateTime @default(now())
  link      LinkSlashLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  tag       LinkSlashTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([linkId, tagId])
  @@index([linkId])
  @@index([tagId])
}

model LinkSlashSyncLog {
  id         String   @id @default(cuid())
  tenantId   String   @default("")
  userId     String
  direction  String
  entityType String
  entityId   String   @default("")
  status     String   @default("ok")
  payloadJson String  @default("{}")
  error      String   @default("")
  createdAt  DateTime @default(now())

  @@index([tenantId, userId, createdAt])
  @@index([entityType, entityId])
}

// ── LinkSlash Phase 2: Device binding, APK releases, activation, import logs ──

model LinkSlashDevice {
  id           String   @id @default(cuid())
  userId       String
  dealerId     String   @default("")
  deviceId     String
  androidId    String   @default("")
  deviceName   String   @default("")
  firstLoginAt DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  status       String   @default("active") // active | revoked
  licenseId    String   @default("")

  @@unique([userId, deviceId])
  @@index([userId, status])
  @@index([dealerId])
}

model LinkSlashActivationCode {
  id             String    @id @default(cuid())
  code           String    @unique
  product        String    @default("LINKSLASH")
  durationDays   Int       @default(365)
  status         String    @default("active") // active | used | revoked
  usedByUserId   String    @default("")
  usedByDealerId String    @default("")
  usedAt         DateTime?
  createdByAdminId String  @default("")
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([product])
}

model LinkSlashImportLog {
  id             String   @id @default(cuid())
  userId         String
  dealerId       String   @default("")
  url            String
  sourcePlatform String   @default("other")
  client         String   @default("mobile")
  status         String   @default("saved")
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([dealerId])
  @@index([sourcePlatform])
  @@index([createdAt])
}

model LinkSlashApkRelease {
  id              String   @id @default(cuid())
  version         String
  buildNumber     Int      @default(1)
  requiredVersion String   @default("")
  fileName        String
  fileSize        Int      @default(0)
  active          Boolean  @default(false)
  uploadedBy      String   @default("")
  uploadedAt      DateTime @default(now())

  @@unique([version])
  @@index([active])
}

model LinkSlashDownloadToken {
  id           String    @id @default(cuid())
  token        String    @unique
  userId       String
  dealerId     String    @default("")
  apkReleaseId String    @default("")
  usedAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════
// ENAUNITY PARTNER ECOSYSTEM — Faz 1
// ═══════════════════════════════════════════

enum PartnerType {
  PROFESSIONAL_DEALER
  SOCIAL_DEALER
  POD_CREATOR
  AI_PARTNER
  // Legacy — mevcut kayıtlar kırılmasın
  CUSTOMER
  AFFILIATE
  BAYI_PLUS
  FRANCHISE
}

enum PartnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ReferralStatus {
  VISIT
  REGISTERED
  LICENSED
  FIRST_ORDER
  CONVERTED
  CANCELLED
}

enum CommissionType {
  PRODUCT_ORDER
  MODULE_LICENSE
  POD_SALE
  NETWORK_OVERRIDE
  FIRST_ORDER
  RECURRING_ORDER
  MANUAL
  // Legacy
  POD_ORDER
}

enum CommissionStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum PayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
  CANCELLED
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model PartnerProfile {
  id                      String        @id @default(cuid())
  userId                  String        @unique
  dealerId                String?
  partnerType             PartnerType   @default(SOCIAL_DEALER)
  referralCode            String        @unique
  referralSlug            String        @unique
  status                  PartnerStatus @default(PENDING)
  sponsorPartnerId        String?
  sponsorPartner          PartnerProfile?  @relation("PartnerSponsor", fields: [sponsorPartnerId], references: [id], onDelete: SetNull)
  sponsoredPartners       PartnerProfile[] @relation("PartnerSponsor")
  defaultCommissionRate   Float         @default(0)
  moduleCommissionRate    Float         @default(0)
  podCommissionRate       Float         @default(0)
  networkOverrideRate     Float         @default(0)
  commissionRate          Float         @default(0)
  recurringCommissionRate Float         @default(0)
  metadataJson            String        @default("{}")
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  referrals   AffiliateReferral[]
  commissions AffiliateCommission[]
  payouts     AffiliatePayout[]
  podStores   PODCreatorStore[]

  @@index([dealerId])
  @@index([partnerType, status])
  @@index([sponsorPartnerId])
}

model PartnerNetworkApplication {
  id              String                 @id @default(cuid())
  userId          String?
  dealerId        String?
  fullName        String
  companyName     String                 @default("")
  email           String
  phone           String                 @default("")
  requestedType   PartnerType
  hasTaxPlate     Boolean                @default(false)
  socialMedia     String                 @default("")
  applicationNote String                 @default("")
  sponsorPartnerId String?
  status          PartnerApplicationStatus @default(PENDING)
  adminNote       String                 @default("")
  reviewedBy      String                 @default("")
  reviewedAt      DateTime?
  metadataJson    String                 @default("{}")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([email])
  @@index([userId])
  @@index([status])
}

model AffiliateReferral {
  id               String         @id @default(cuid())
  partnerId        String
  partner          PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referredUserId   String?
  referredDealerId String?
  referralCode     String
  sourceUrl        String?
  landingPath      String?
  ipHash           String?
  userAgent        String?
  status           ReferralStatus @default(VISIT)
  createdAt        DateTime       @default(now())
  convertedAt      DateTime?

  commissions AffiliateCommission[]

  @@index([partnerId])
  @@index([referralCode])
  @@index([referredUserId])
  @@index([referredDealerId])
  @@index([ipHash, createdAt])
}

model AffiliateCommission {
  id              String           @id @default(cuid())
  partnerId       String
  partner         PartnerProfile   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referralId      String?
  referral        AffiliateReferral? @relation(fields: [referralId], references: [id], onDelete: SetNull)
  orderId         String?
  moduleLicenseId String?
  commissionType  CommissionType
  baseAmount      Float            @default(0)
  rate            Float            @default(0)
  amount          Float            @default(0)
  status          CommissionStatus @default(PENDING)
  payoutId        String?
  payout          AffiliatePayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  note            String?
  createdAt       DateTime         @default(now())
  approvedAt      DateTime?
  paidAt          DateTime?

  @@index([partnerId, status])
  @@index([partnerId, status, payoutId])
  @@index([orderId])
  @@index([payoutId])
}

model AffiliatePayout {
  id                String         @id @default(cuid())
  partnerId         String
  partner           PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  amount            Float          @default(0)
  currency          String         @default("TRY")
  status            PayoutStatus   @default(REQUESTED)
  iban              String         @default("")
  accountHolder     String         @default("")
  taxIdentityNumber String?
  invoiceUrl        String?
  note              String?
  adminNote         String?
  paymentMethod     String?
  paymentNote       String?
  requestedAt       DateTime       @default(now())
  processedAt       DateTime?
  paidAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  commissions       AffiliateCommission[]

  @@index([partnerId, status])
  @@index([status, requestedAt])
}

model PODProductTemplate {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  category     String   @default("")
  basePrice    Float    @default(0)
  printAreasJson String @default("[]")
  status       String   @default("draft")
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  designs PODDesign[]
}

model PODDesign {
  id         String   @id @default(cuid())
  templateId String?
  template   PODProductTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  storeId    String?
  store      PODCreatorStore? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  creatorUserId String
  title      String   @default("")
  previewUrl String   @default("")
  status     String   @default("draft")
  metadataJson String @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders PODOrder[]
}

model PODCreatorStore {
  id               String   @id @default(cuid())
  partnerId        String?
  partner          PartnerProfile? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  ownerUserId      String
  name             String
  slug             String   @unique
  status           String   @default("draft")
  metadataJson     String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  designs PODDesign[]
  orders  PODOrder[]
}

model PODOrder {
  id         String   @id @default(cuid())
  storeId    String?
  store      PODCreatorStore? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  designId   String?
  design     PODDesign? @relation(fields: [designId], references: [id], onDelete: SetNull)
  orderId    String   @default("")
  amount     Float    @default(0)
  status     String   @default("pending")
  metadataJson String @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  commissions PODCommission[]
}

model PODCommission {
  id        String   @id @default(cuid())
  podOrderId String
  podOrder  PODOrder @relation(fields: [podOrderId], references: [id], onDelete: Cascade)
  partnerProfileId String @default("")
  amount    Float    @default(0)
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([podOrderId])
  @@index([partnerProfileId])
}

// ── AI Page Factory (topology / cluster / blueprint — içerik üretmez) ──

model PageFactoryProject {
  id             String   @id @default(cuid())
  dealerId       String?
  name           String
  slug           String   @unique
  sector         String
  country        String   @default("TR")
  language       String   @default("tr")
  productionType String   // GEO | SEO | GEO_SEO | FAQ | BLOG | PRODUCT | SERVICE | MIXED
  status         String   @default("draft")
  metadataJson   String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  topologies PageFactoryTopology[]
  blueprints PageFactoryBlueprint[]

  @@index([dealerId])
  @@index([status])
}

model PageFactoryTopology {
  id           String   @id @default(cuid())
  projectId    String
  project      PageFactoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  topologyType String   // geo | location | product | question | intent
  nodeCount    Int      @default(0)
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([topologyType])
}

model PageFactoryBlueprint {
  id             String   @id @default(cuid())
  projectId      String
  project        PageFactoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  pageType       String
  hierarchyLevel Int      @default(0)
  clusterPath    String   @default("")
  metadataJson   String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([hierarchyLevel])
}

// ── Data Universe Engine (GEO / Industry / Intent / Question — içerik üretmez) ──

model GeoCountry {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provinces GeoProvince[]

  @@index([isActive])
  @@index([code])
}

model GeoProvince {
  id        String     @id @default(cuid())
  countryId String
  country   GeoCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  plateCode String
  name      String
  slug      String
  latitude  Float?
  longitude Float?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  districts GeoDistrict[]

  @@unique([countryId, slug])
  @@index([countryId])
  @@index([plateCode])
  @@index([isActive])
  @@index([name])
}

model GeoDistrict {
  id         String      @id @default(cuid())
  provinceId String
  province   GeoProvince @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  latitude   Float?
  longitude  Float?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  neighborhoods GeoNeighborhood[]
  villages      GeoVillage[]

  @@unique([provinceId, slug])
  @@index([provinceId])
  @@index([isActive])
  @@index([name])
}

model GeoNeighborhood {
  id         String      @id @default(cuid())
  districtId String
  district   GeoDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  latitude   Float?
  longitude  Float?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  streets GeoStreet[]

  @@unique([districtId, slug])
  @@index([districtId])
  @@index([isActive])
  @@index([name])
}

model GeoStreet {
  id             String          @id @default(cuid())
  neighborhoodId String
  neighborhood   GeoNeighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  latitude       Float?
  longitude      Float?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([neighborhoodId, slug])
  @@index([neighborhoodId])
  @@index([isActive])
  @@index([name])
}

model GeoVillage {
  id         String      @id @default(cuid())
  districtId String
  district   GeoDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  latitude   Float?
  longitude  Float?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([districtId, slug])
  @@index([districtId])
  @@index([isActive])
  @@index([name])
}

model Industry {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories IndustryCategory[]

  @@index([isActive])
  @@index([name])
}

model IndustryCategory {
  id          String   @id @default(cuid())
  industryId  String
  industry    Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([industryId, slug])
  @@index([industryId])
  @@index([isActive])
}

model SearchIntent {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([name])
}

model QuestionPattern {
  id        String   @id @default(cuid())
  title     String
  pattern   String
  type      String   @default("general")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model DataUniverseImportJob {
  id           String    @id @default(cuid())
  type         String
  status       String    @default("PENDING")
  fileName     String    @default("")
  dryRun       Boolean   @default(false)
  totalRows    Int       @default(0)
  insertedRows Int       @default(0)
  updatedRows  Int       @default(0)
  skippedRows  Int       @default(0)
  errorRows    Int       @default(0)
  metadataJson String    @default("{}")
  createdById  String    @default("")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([status])
  @@index([type])
  @@index([createdAt])
}
