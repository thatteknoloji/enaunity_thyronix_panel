// ── NEXA Models ──

enum ThyronixTenantScope {
  GLOBAL
  DEALER
}

enum ThyronixOwnerType {
  ADMIN
  DEALER
}

model ThyronixSource {
  id           String   @id @default(cuid())
  name         String
  xmlUrl       String
  type         String   @default("xml")
  inputFormat  String   @default("custom_xml")
  fieldMapping String?  // JSON: custom field mapping overrides
  fixedValues  String?  // JSON: fixed values {brand:"X", weight:"4"}
  interval     Int      @default(60)
  status      String   @default("active")
  lastSync    DateTime?
  productCount Int     @default(0)
  errorLog    String?
  dealerId     String?
  tenantScope  ThyronixTenantScope @default(GLOBAL)
  ownerType    ThyronixOwnerType   @default(ADMIN)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  ThyronixProduct[]
  @@index([status])
  @@index([name])
  @@index([dealerId])
  @@index([tenantScope])
}

model ThyronixProduct {
  id              String   @id @default(cuid())
  sourceId        String
  source          ThyronixSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  externalId      String
  name            String
  description     String?
  brand           String?
  category        String?
  barcode         String?
  stockCode       String?
  modelCode       String?
  price           Float    @default(0)
  discountedPrice Float?
  stock           Int      @default(0)
  images          String?
  currency        String   @default("TRY")
  variantData     String?  // JSON: variant array from source XML

  status          String   @default("active")
  lockedFields    String?
  confidence      Float?
  dealerId        String?
  tenantScope     ThyronixTenantScope @default(GLOBAL)
  ownerType       ThyronixOwnerType   @default(ADMIN)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sourceId, externalId])
  @@index([status])
  @@index([barcode])
  @@index([stockCode])
  @@index([modelCode])
  @@index([category])
  @@index([brand])
  @@index([price])
  @@index([stock])
  @@index([createdAt])
  @@index([sourceId, barcode])
  @@index([sourceId, stockCode])
  @@index([sourceId, modelCode])
  @@index([sourceId, status])
  @@index([sourceId, createdAt])
  @@index([name])
  @@index([dealerId])
  @@index([tenantScope])
}

model ThyronixFeed {
  id            String    @id @default(cuid())
  name          String
  channel       String
  status        String    @default("active")
  productCount  Int       @default(0)
  url           String?
  interval      Int       @default(60)
  outputFormat  String    @default("jetteknoloji")
  mergeStrategy String    @default("lowest_price")
  schedule      Int       @default(24)
  lastPublished DateTime?
  dealerId      String?
  tenantScope   ThyronixTenantScope @default(GLOBAL)
  ownerType     ThyronixOwnerType   @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt    DateTime @updatedAt
  @@index([status])
  @@index([dealerId])
  @@index([tenantScope])
}

model ThyronixRule {
  id           String   @id @default(cuid())
  name         String
  description  String?
  priority     Int      @default(0)
  field        String
  operator     String
  value        String
  action       String
  actionValue  String?
  status       String   @default("active")
  affectedCount Int     @default(0)
  dealerId      String?
  tenantScope   ThyronixTenantScope @default(GLOBAL)
  ownerType     ThyronixOwnerType   @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([status])
  @@index([dealerId])
  @@index([tenantScope])
}

model ThyronixSyncLog {
  id          String   @id @default(cuid())
  type        String
  referenceId String?
  status      String
  message     String?
  productCount Int?
  duration    Int?
  createdAt   DateTime @default(now())
  @@index([type])
  @@index([createdAt])
  @@index([type, createdAt])
}

model ThyronixExclusion {
