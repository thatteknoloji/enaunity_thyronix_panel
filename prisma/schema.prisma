generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id @default(cuid())
  email     String          @unique
  name      String
  password  String
  role      String          @default("user")
  status    String          @default("active") // pending, active, rejected, suspended
  phone     String          @default("")
  company   String          @default("")
  taxNumber String          @default("")
  taxOffice String          @default("")
  kvkkAcceptedAt DateTime?
  contractsAcceptedJson String @default("[]")
  approvalChecklistJson String @default("{}")
  adminApprovalWaiversJson String @default("{}")
  adminNote String          @default("")
  rejectionReason String    @default("")
  approvedAt DateTime?
  reviewedBy String         @default("")
  dealerId  String?
  dealer    Dealer?         @relation(fields: [dealerId], references: [id])
  adminRoleId String?
  adminRole   AdminRole?    @relation(fields: [adminRoleId], references: [id])
  totpSecret String?
  totpEnabled Boolean       @default(false)
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  orders    Order[]
  cart      Cart?
  reviews   Review[]
  productAccountLinks ProductAccountLink[]
  appearance          UserAppearance?
  memberDocuments     MemberDocument[]
  legalAcceptances    LegalAcceptance[]
  cookieConsents      CookieConsent[]
  legalReacceptTasks  LegalReacceptanceTask[]
  legalReacceptStatus String          @default("ok") // ok | pending_reacceptance
}

model MemberDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("")
  type      String   // tax_levy, signature_circular, trade_registry
  fileUrl   String
  fileName  String   @default("")
  fileSize  Int      @default(0)
  status    String   @default("pending") // pending, approved, rejected
  adminNote String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserAppearance {
  id            String   @id @default(cuid())
  userId        String   @unique
  theme         String   @default("dark")
  accent        String   @default("orange")
  compactMode   Boolean  @default(false)
  reducedMotion Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  permissions String   @default("[]")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  target    String   @default("")
  detail    String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())
}

model Product {
  id                String                @id @default(cuid())
  name              String
  slug              String                @default("") @unique
  description       String
  price             Float
  costPrice         Float                 @default(0)
  image             String                @default("/placeholder.svg")
  images            String                @default("[]")
  category          String                @default("general")
  subcategory       String                @default("")
  brand             String                @default("")
  sku               String                @default("")
  barcode           String                @default("")
  modelCode         String                @default("")
  specs             String                @default("[]")
  weight            Float                 @default(0)
  dimensions        String                @default("")
  tags              String                @default("")
  stock             Int                   @default(0)
  minStockLevel     Int                   @default(0)
  maxStockLevel     Int                   @default(0)
  minOrderQuantity  Int                   @default(1)
  variantDisplayMode String               @default("buttons") // buttons, select, modal, popup, drawer, grid
  salePrice         Float                 @default(0)
  discountLabel     String                @default("")
  subtitle          String                @default("")
  shortDescription  String                @default("")
  badgeText         String                @default("")
  highlightsJson    String                @default("[]")
  trustBadgesJson   String                @default("[]")
  backorderable     Boolean               @default(false)
  eta               String                @default("")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  orderItems        OrderItem[]
  cartItems         CartItem[]
  priceListEntries  PriceList[]
  catalogRestrictions CatalogRestriction[]
  stockMovements    StockMovement[]
  warehouseStocks   ProductWarehouse[]
  quoteItems        QuoteItem[]
  tieredPrices      TieredPrice[]
  dealerPrices      DealerPrice[]
  returnItems       ReturnItem[]
  campaignProducts  CampaignProduct[]
  bundleItems       BundleItem[]
  shippingConfigs   ShippingConfig[]
  variants          Variant[]
  variantGroups     VariantGroup[]
  reviews           Review[]
  stockCountItems   StockCountItem[]
  favoriteProducts  FavoriteProduct[]
  savedCartItems    SavedCartItem[]
}

model VariantGroup {
  id         String          @id @default(cuid())
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  name       String
  sortOrder  Int             @default(0)
  options    VariantOption[]
  createdAt DateTime @default(now())
}

model Campaign {
  id            String            @id @default(cuid())
  name          String
  description   String            @default("")
  type          String            // bogo, bundle, quantity_discount, free_shipping, category_discount, first_order, loyalty
  discountType  String            @default("percentage") // percentage, fixed
  discountValue Float             @default(0)
  minAmount     Float             @default(0)
  maxDiscount   Float             @default(0)
  minQuantity   Int               @default(0)
  bundlePrice   Float             @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  active        Boolean           @default(true)
  targetType    String            @default("all") // all, users, dealers, dealerGroups
  targetIds     String            @default("[]")  // JSON array of IDs
  categoryScope String            @default("[]")  // JSON array for category_discount
  orderCountMin     Int          @default(0)
  freeShipping      Boolean      @default(false)
  badge         String            @default("")
  badgeColor    String            @default("#e50914")
  showOnHomepage     Boolean        @default(false)
  bannerSlotKey      String         @default("after_hero")
  bannerImageDesktop String         @default("")
  bannerImageTablet  String         @default("")
  bannerImageMobile  String         @default("")
  bannerLinkUrl      String         @default("")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  products      CampaignProduct[]
  homepageBanners HomeBanner[]
}

model CampaignProduct {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  type       String    @default("buy") // buy, get
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  quantity   Int       @default(1)

  @@unique([campaignId, type, productId])
}

model VariantOption {
  id        String       @id @default(cuid())
  groupId   String
  group     VariantGroup @relation(fields: [groupId], references: [id])
  value     String
  sortOrder Int          @default(0)
}

model Variant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  sku        String   @default("")
  barcode    String   @default("")
  price      Float    @default(0)
  stock      Int      @default(0)
  options    String   @default("[]")
  image      String   @default("")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  parentId   String?
  parent     Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryChildren")
  image      String     @default("")
  sortOrder  Int        @default(0)
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model ApiKey {
  id         String   @id @default(cuid())
  dealerId   String?
  dealer     Dealer?  @relation(fields: [dealerId], references: [id])
  key        String   @unique
  name       String   @default("")
  rateLimit  Int      @default(60)
  lastUsed   DateTime?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TieredPrice {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  minQuantity Int
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, minQuantity])
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  dealerId   String?
  dealer     Dealer?     @relation(fields: [dealerId], references: [id])
  subUserId  String?
  subUser    SubUser?    @relation(fields: [subUserId], references: [id])
  items      OrderItem[]
  total      Float
  discount   Float       @default(0)
  couponId   String?
  coupon     Coupon?     @relation(fields: [couponId], references: [id])
  status     String      @default("pending")
  notes      String      @default("")
  address    String
  trackingNumber String  @default("")
  carrier    String      @default("")
  hasBackorder Boolean   @default(false)
  paymentTermDays Int    @default(0)
  paymentTermRate Float  @default(0)
  orderNumber        String   @default("")
  marketplace        String   @default("")
  marketplaceOrderId String   @default("")
  sourceType         String   @default("B2B")
  thyronixRef        String   @default("")
  totalCost          Float    @default(0)
  totalProfit        Float    @default(0)
  fulfillmentStatus  String   @default("")
  customerName       String   @default("")
  customerPhone      String   @default("")
  customerCity       String   @default("")
  metadataJson       String   @default("{}")
  paymentDeadlineAt  DateTime?
  receiptReminderSent Boolean  @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  payments   Payment[]
  stockMovements StockMovement[]
  statusHistory  OrderStatusHistory[]
  returnRequests ReturnRequest[]
  dealerTransactions DealerTransaction[]
  attachments      OrderAttachment[]
  costItems        DealerCostItem[]
  accountTransactions DealerAccountTransaction[] @relation("CoreOrderAccountTx")
  shipments        DealerShipment[] @relation("CoreOrderShipments")
  warehouseMovements DealerWarehouseMovement[] @relation("CoreOrderWarehouse")
  invoices         Invoice[]

  @@index([dealerId])
  @@index([marketplaceOrderId])
  @@index([fulfillmentStatus])
  @@index([sourceType])
  @@index([orderNumber])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  note      String   @default("")
  changedBy String   @default("system") // system, dealer, admin
  createdAt DateTime @default(now())
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  order                Order    @relation(fields: [orderId], references: [id])
  productId            String?
  product              Product? @relation(fields: [productId], references: [id])
  productCatalogItemId String?
  productCatalogItem   ProductCatalogItem? @relation(fields: [productCatalogItemId], references: [id], onDelete: SetNull)
  name                 String   @default("")
  quantity             Int
  price                Float
  sku                  String   @default("")
  barcode              String   @default("")
  costPrice            Float    @default(0)
  profitAmount         Float    @default(0)
  thyronixProductId    String   @default("")
  sourceType           String   @default("")
  metadataJson         String   @default("{}")
}

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String  @default("")
  quantity  Int
}

model PartnerApplication {
  id            String   @id @default(cuid())
  partnerType   String
  name          String
  title         String
  email         String
  phone         String
  company       String
  website       String   @default("")
  location      String
  companySize   String
  markets       String
  portfolio     String   @default("")
  techLevel     String   @default("")
  motivation    String   @default("")
  files         String   @default("[]")
  kvkk          Boolean  @default(false)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DealerGroup {
  id                  String   @id @default(cuid())
  name                String   @unique
  discountRate        Float    @default(0)
  creditLimit         Float    @default(0)
  allowNegativeBalance Boolean @default(false)
  minOrderAmount      Float    @default(0)
  paymentDays         Int      @default(0)
  rules               String   @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  dealers             Dealer[]
}

model Dealer {
  id              String             @id @default(cuid())
  name            String
  title           String
  email           String             @unique
  phone           String
  company         String
  website         String             @default("")
  location        String
  companySize     String
  markets         String
  discountRate    Float              @default(0)
  group           String             @default("bronze")
  dealerGroup     DealerGroup?       @relation(fields: [group], references: [name])
  creditLimit     Float              @default(0)
  openingBalance  Float              @default(0)
  balance         Float              @default(0)
  allowNegative   Boolean            @default(false)
  taxNumber       String             @default("")
  taxOffice       String             @default("")
  billingAddress  String             @default("")
  shippingAddress String             @default("")
  logo            String             @default("")
  status          String             @default("active")
  orders          Order[]
  users           User[]
  payments        Payment[]
  quotes          Quote[]
  notifications   Notification[]
  subUsers        SubUser[]
  dealerPrices    DealerPrice[]
  paymentTerm     PaymentTerm?
  dealerTransactions DealerTransaction[]
  returnRequests  ReturnRequest[]
  apiKeys         ApiKey[]
  favoriteProducts FavoriteProduct[]
  savedCarts       SavedCart[]
  assignments      DealerAssignment[]
  addresses        Address[]
  dealerContracts  DealerContract[]
  dealerDocuments  DealerDocument[]
  invoices         Invoice[]
  telegramChatId   String             @default("")
  marketplaceConnections MarketplaceConnection[]
  dealerOrders           DealerOrder[]
  dealerAccount          DealerAccount?
  dealerAccountTransactions DealerAccountTransaction[]
  dealerStatements       DealerStatement[]
  dealerWarehouseMovements DealerWarehouseMovement[]
  dealerProducts         DealerProduct[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model DealerPrice {
  id        String   @id @default(cuid())
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, productId])
}

// Bayi kendi tanımladığı ürünler (foto + PDF + ebat) — katalog eşleştirme yok
model DealerProduct {
  id           String   @id @default(cuid())
  dealerId     String
  dealer       Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  name         String
  description  String   @default("")
  imageUrl     String
  specPdfUrl   String
  variantsJson String   @default("[]")
  basePrice    Float    @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dealerId])
  @@index([active])
}

model PriceList {
  id        String   @id @default(cuid())
  group     String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([group, productId])
}

model CatalogRestriction {
  id        String   @id @default(cuid())
  group     String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([group, productId])
}

model Payment {
  id        String   @id @default(cuid())
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id])
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amount    Float
  type      String   @default("payment")
  status    String   @default("COMPLETED")
  note      String   @default("")
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([dealerId])
}

model StockMovement {
  id          String     @id @default(cuid())
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  type        String     // IN, OUT, RESERVE, RELEASE_RESERVE, RETURN, ADJUSTMENT, TRANSFER (+ legacy: entry, exit, adjustment, return)
  quantity    Int
  note        String     @default("")
  orderId     String?
  order       Order?     @relation(fields: [orderId], references: [id])
  createdAt   DateTime   @default(now())

  @@index([productId])
  @@index([orderId])
  @@index([type])
  @@index([warehouseId])
}

model Warehouse {
  id        String             @id @default(cuid())
  name      String
  location  String             @default("")
  isDefault Boolean            @default(false)
  stocks    ProductWarehouse[]
  stockCounts StockCount[]
  stockMovements StockMovement[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model ProductWarehouse {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  stock       Int       @default(0)

  @@unique([productId, warehouseId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String?
  dealerId   String?
  dealer     Dealer?  @relation(fields: [dealerId], references: [id])
  campaignId String?
  campaign   NotificationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  title      String
  message    String
  type       String   @default("info")
  read       Boolean  @default(false)
  link       String   @default("")
  createdAt  DateTime @default(now())

  @@index([campaignId])
  @@index([userId, read])
  @@index([dealerId, read])
}

model NotificationCampaign {
  id                 String   @id @default(cuid())
  title              String
  message            String
  emailSubject       String   @default("")
  emailHtml          String   @default("")
  channel            String   @default("panel_and_email") // panel_only | email_only | panel_and_email
  audience           String   @default("all") // all | members | dealers | custom
  audienceFilterJson String   @default("{}")
  link               String   @default("")
  type               String   @default("announcement")
  status             String   @default("draft") // draft | scheduled | sending | sent | cancelled
  scheduledAt        DateTime?
  sentAt             DateTime?
  timezone           String   @default("Europe/Istanbul")
  recipientCount     Int      @default(0)
  deliveredCount     Int      @default(0)
  emailSentCount     Int      @default(0)
  createdById        String   @default("")
  createdByName      String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  notifications      Notification[]
  deliveries         NotificationDelivery[]

  @@index([status, scheduledAt])
}

model NotificationDelivery {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       NotificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId         String?
  dealerId       String?
  email          String   @default("")
  channel        String
  status         String   @default("pending") // pending | delivered | failed | skipped
  error          String   @default("")
  notificationId String   @default("")
  createdAt      DateTime @default(now())

  @@index([campaignId])
}

model Quote {
  id             String      @id @default(cuid())
  dealerId       String
  dealer         Dealer      @relation(fields: [dealerId], references: [id])
  items          QuoteItem[]
  status         String      @default("pending") // pending, approved, rejected, countered
  note           String      @default("")
  adminNote      String      @default("")
  total          Float       @default(0)
  validUntil     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   @default(0)
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("percentage") // percentage, fixed
  value       Float    // 10 = %10 or 100 = 100TL
  minAmount   Float    @default(0)
  maxDiscount Float    @default(0) // 0 = unlimited
  usageLimit  Int      @default(0) // 0 = unlimited
  usageCount  Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model SubUser {
  id        String   @id @default(cuid())
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id])
  name      String
  email     String   @unique
  password  String
  role      String   @default("orderer") // viewer, orderer, admin
  active    Boolean  @default(true)
  totpSecret String?
  totpEnabled Boolean @default(false)
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model PaymentTerm {
  id        String   @id @default(cuid())
  dealerId  String   @unique
  dealer    Dealer   @relation(fields: [dealerId], references: [id])
  days      Int      @default(30)
  rate      Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReturnRequest {
  id        String       @id @default(cuid())
  dealerId  String
  dealer    Dealer       @relation(fields: [dealerId], references: [id])
  orderId   String?
  order     Order?       @relation(fields: [orderId], references: [id])
  reason    String       @default("")
  status    String       @default("pending")
  adminNote String       @default("")
  items     ReturnItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ReturnItem {
  id        String        @id @default(cuid())
  requestId String
  request   ReturnRequest @relation(fields: [requestId], references: [id])
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float         @default(0)
}

model DealerTransaction {
  id           String   @id @default(cuid())
  dealerId     String
  dealer       Dealer   @relation(fields: [dealerId], references: [id])
  type         String
  amount       Float
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id])
  note         String   @default("")
  balanceAfter Float    @default(0)
  createdAt   DateTime @default(now())
}

model ThyronixAiSuggestion {
  id              String   @id @default(cuid())
  productId       String
  taskType        String   // title_optimize, description_generate, category_suggest, attribute_extract, quality_improve
  originalValue   String   @default("")
  suggestedValue  String
  status          String   @default("pending") // pending, accepted, rejected, applied
  providerId      String   @default("")
  model           String   @default("")
  tokenUsage      Int      @default(0)
  cost            Float    @default(0)
  fieldLocked     Boolean  @default(false)
  createdAt       DateTime @default(now())
  appliedAt       DateTime?
  rejectedAt      DateTime?
  @@index([productId])
  @@index([status])
  @@index([productId, status])
}

model ThyronixAiJob {
  id              String   @id @default(cuid())
  name            String
  taskType        String
  status          String   @default("pending") // pending, running, paused, completed, failed, cancelled
  totalProducts   Int      @default(0)
  processedCount  Int      @default(0)
