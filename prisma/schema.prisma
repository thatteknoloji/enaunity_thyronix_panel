  dealerId  String?
  tenantScope ThyronixTenantScope @default(GLOBAL)
  ownerType   ThyronixOwnerType   @default(ADMIN)
  createdAt DateTime @default(now())
  @@index([dealerId])
  @@index([tenantScope])
}

model ThyronixBrandMapping {
