# Database
DATABASE_URL="file:./dev.db"

# Admin secret path (optional)
# ADMIN_SECRET_PATH="/x-control-eu-7294"

# Marketplace engine — hub is the single active sync motor
MARKETPLACE_ENGINE=hub
LEGACY_MARKETPLACE_ENABLED=false

# Mirror for client-side nav (keep in sync with LEGACY_MARKETPLACE_ENABLED)
NEXT_PUBLIC_LEGACY_MARKETPLACE_ENABLED=false

# Allow mock Trendyol packages in non-production only (never set true in production)
# MARKETPLACE_ALLOW_MOCK=false

# Accounting engine — dealer_account is the single source of truth
ACCOUNTING_ENGINE=dealer_account
LEGACY_DEALER_BALANCE_ENABLED=false

# Order engine — core is the single source for new orders
ORDER_ENGINE=core
LEGACY_DEALER_ORDER_ENABLED=false
DEALER_ORDER_MIRROR_ENABLED=false

# Warehouse engine — core is the single source for stock operations
WAREHOUSE_ENGINE=core
LEGACY_DEALER_WAREHOUSE_ENABLED=false
DEALER_WAREHOUSE_MIRROR_ENABLED=false

# Invoice engine — invoice_model is the single source for financial documents
INVOICE_ENGINE=invoice_model
LEGACY_ORDER_PDF_ENABLED=false

# Payment gateways (enable in production)
ESNEKPOS_ENABLED=
IYZICO_ENABLED=

# HIVE module
HIVE_ENABLED=
HIVE_SALES_ACTIVE=false
# HIVE_BASE_URL=https://hive.thiqos.com
# HIVE_PROXY_MODE=internal

# Live deploy (put real values in .env.local — never commit)
# ENAUNITY_SSH_HOST=13.140.138.135
# ENAUNITY_SSH_USER=root
# ENAUNITY_SSH_PASS=
# ENAUNITY_APP_DIR=/opt/enaunity
